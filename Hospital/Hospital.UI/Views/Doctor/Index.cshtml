@model DoctorListViewModel

<div class="doctores_section margim_90">
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <h1 class="doctores_taital">Our Doctors</h1>
            </div>
        </div>

      
        <div class="row mb-4">
            <div class="col-md-12 d-flex align-items-center">
                <input type="text" id="doctorSearch" class="form-control me-2"
                       placeholder="Enter the name of the doctor you are looking for "
                       style="max-width: 250px; height:40px" />
                <button type="button" class="btn btn-primary h-100" id="searchButton">Search</button>
            </div>
        </div>

        <div class="row" id="doctorContainer">
            @foreach (var doctor in Model.Doctors)
            {
                <div class="col-md-4">
                    <div class="doctores_box">
                        <div class="image_1">
                            <img src="@(string.IsNullOrEmpty(doctor.ImagePath)
                                                                               ? Url.Content("~/images/default-doctor.jpg")
                                                                               : Url.Content(doctor.ImagePath))" />
                    </div>
                    <h4 class="humour_text">@doctor.FullName <br></h4>
                    <p>@doctor.Department?.Name</p>  
                    <form asp-controller="Doctor" asp-action="ToggleFavorite" method="post" class="favorite-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="doctorId" value="@doctor.Id" />
                        <button type="submit" class="btn btn-link p-0">
                            <i class="@(Model.UserFavoriteDoctorIds.Contains(doctor.Id)
                                                   ? "fa fa-heart text-danger"
                                                   : "fa fa-heart-o")" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </div>
                        }
        </div>
    </div>
</div>

<script>
    const searchInput = document.getElementById('doctorSearch');
    const searchButton = document.getElementById('searchButton');
    const doctorBoxes = document.querySelectorAll('.doctores_box');

    function filterDoctors() {
        const filter = searchInput.value.toLowerCase().trim();

        doctorBoxes.forEach(box => {
            const name = box.querySelector('h4').innerText.toLowerCase();
            const department = box.querySelector('p') ? box.querySelector('p').innerText.toLowerCase() : '';

            if(name.includes(filter) || department.includes(filter)) {
                box.parentElement.style.display = ''; 
            } else {
                box.parentElement.style.display = 'none'; 
            }
        });
    }

    
    searchInput.addEventListener('input', filterDoctors);

   
    searchButton.addEventListener('click', filterDoctors);
</script>
